# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database for host-based development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/proximum_exemplar"
DATABASE_POOL_MAX="5"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_PROXY_URL=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Redis for host-based development
REDIS_URL="redis://localhost:6379"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_replace_me"
BLOB_UPLOAD_MAX_BYTES="10485760"

# Vercel Cron
CRON_SECRET="replace-with-at-least-16-characters"

# AI
AI_PROVIDER="openrouter"
AI_DEFAULT_MODEL="gemini-2.5-flash"
OPENROUTER_API_KEY=""
OPENROUTER_DEFAULT_MODEL="deepseek/deepseek-v4-flash"
GOOGLE_GENERATIVE_AI_API_KEY=""
